# =============================================================================
# Matryca Plumber — environment template (aligned with src/)
# =============================================================================
# On first startup Matryca copies this file to ".env" when missing; edit values below.
# Safe-by-default: mutating lint, git snapshots,
# flock degradation, MCP stdio, and context compression are OFF unless you opt in.
#
# Startup: Matryca creates missing log dirs, <parent-of-vault>/matryca-l1/, cache,
# templates/, and matryca-wiki.yml (from example) before graph work — see
# docs/openspec/runtime-bootstrap.md.
#
# Security (Ironclad): shared SSRF policy for UI + daemon LLM URLs; graph path
# allowlist for Settings saves; MCP stdio gated by MATRYCA_MCP_ENABLED; split UI
# rate limits for authenticated vs anonymous /api/* traffic.
# =============================================================================

# -----------------------------------------------------------------------------
# Graph & wiki paths
# -----------------------------------------------------------------------------
# Absolute path to your Logseq graph root (must contain a pages/ directory).
LOGSEQ_GRAPH_PATH="/absolute/path/to/your/Logseq/graph"

# Optional: L1 memory Markdown file or directory (see src/agent/l1_memory.py).
# When unset, Matryca uses <parent-of-graph>/matryca-l1/ (created automatically at startup).
MATRYCA_L1_PATH="/absolute/path/to/matryca-l1"

# Optional: explicit path to matryca-wiki.yml; when empty, uses
# <LOGSEQ_GRAPH_PATH>/matryca-wiki.yml when that file exists (src/config.py).
MATRYCA_WIKI_CONFIG=

# -----------------------------------------------------------------------------
# Local LLM (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Recommended default model id for local inference (LM Studio, llama.cpp, etc.).
MATRYCA_LM_MODEL="gemma-4-e4b-it"

# Base URL for the OpenAI-compatible API (/v1 is appended for bare host roots).
MATRYCA_LM_BASE_URL=http://localhost:1234/v1

# Optional legacy aliases: when non-empty, they override MATRYCA_LM_BASE_URL /
# MATRYCA_LM_MODEL (see resolve_llm_base_url / resolve_llm_model_name in
# src/agent/plumber_config.py). The Settings UI persists these names.
# LLM_BASE_URL=
# LLM_MODEL_NAME=

# API key sent to the local server (often ignored); default matches code fallback.
LLM_API_KEY=dummy-key

# -----------------------------------------------------------------------------
# Instructor / structured LLM output
# -----------------------------------------------------------------------------
# Primary and fallback parsing strategies for structured completions
# (src/agent/maintenance_daemon.py).
MATRYCA_LM_INSTRUCTOR_MODE=JSON_SCHEMA
MATRYCA_LM_INSTRUCTOR_FALLBACK=MD_JSON

# -----------------------------------------------------------------------------
# Daemon & polling
# -----------------------------------------------------------------------------
# Seconds between maintenance daemon poll cycles (default 30 in code).
MATRYCA_PLUMBER_POLL_SECONDS=30

# -----------------------------------------------------------------------------
# Logging (disk)
# -----------------------------------------------------------------------------
# JSONL operations log for token-accurate LLM tracing (src/utils/token_logger.py).
MATRYCA_PLUMBER_LOG_PATH="logs/matryca_plumber_ops.log"

# Rotating Loguru application log path (src/utils/logging_config.py).
MATRYCA_LOGURU_LOG_PATH="logs/matryca_plumber.log"

# -----------------------------------------------------------------------------
# Safety, diagnostics, locking, UI auth, and MCP
# -----------------------------------------------------------------------------
# When true, attempt a git commit before graph writes (opt-in; src/agent/git_snapshot.py).
MATRYCA_GIT_SNAPSHOT_ON_WRITE=false

# Verbose telemetry: unredacted UUIDs/payload markers and full MCP tool errors.
MATRYCA_DEBUG=false

# When true, allow running without POSIX flock when unavailable (risk: weaker
# cross-process serialization). Default in code is off (src/graph/page_write_lock.py).
MATRYCA_ALLOW_FLOCK_DEGRADATION=false

# Enable FastMCP stdio when ``matryca-plumber`` is invoked without CLI args (off by
# default). Set true for Claude Desktop / Cursor MCP hosts (src/plumber_entry.py).
MATRYCA_MCP_ENABLED=false

# Optional bearer token for the Sovereign UI API; empty = auto-generated per process
# (src/cli/ui_auth.py). Required when MATRYCA_UI_ALLOW_LAN=true.
MATRYCA_UI_TOKEN=

# When true, bind the UI to 0.0.0.0 (LAN). GET /api/auth/session stays loopback-only.
MATRYCA_UI_ALLOW_LAN=false

# Expose FastAPI /docs and /openapi.json (off by default).
MATRYCA_UI_ENABLE_DOCS=false

# Per-IP requests per minute for authenticated /api/* (except /api/health,
# /api/auth/session). Unauthenticated budget applies to missing/invalid tokens.
MATRYCA_UI_RATE_LIMIT_PER_MINUTE=120
MATRYCA_UI_RATE_LIMIT_UNAUTH_PER_MINUTE=30

# Extra directories allowed for LOGSEQ_GRAPH_PATH when saving from the Settings UI
# (home, repo, temp, and current graph are always allowed — src/utils/config_paths.py).
# MATRYCA_ALLOWED_GRAPH_ROOTS=

# Redact secrets in MATRYCA_PLUMBER_LOG_PATH JSONL (default on).
MATRYCA_PLUMBER_LOG_REDACT_SECRETS=true

# -----------------------------------------------------------------------------
# Thermal pauses & process priority (resource-friendly defaults)
# -----------------------------------------------------------------------------
# Seconds to sleep after bootstrap vs cognitive LLM turns (defaults 2.0 in
# src/agent/plumber_config.py).
MATRYCA_THERMAL_DELAY_BOOTSTRAP=2.0
MATRYCA_THERMAL_DELAY_COGNITIVE=2.0

# Prefer low-priority scheduling where supported (default true in code).
MATRYCA_PLUMBER_LOW_PRIORITY_MODE=true

# -----------------------------------------------------------------------------
# Map-reduce chunking (large-page handling)
# -----------------------------------------------------------------------------
MATRYCA_PLUMBER_MAPREDUCE_TRIGGER_CHARS=25000
MATRYCA_PLUMBER_MAPREDUCE_CHUNK_CHARS=15000

# -----------------------------------------------------------------------------
# Context compression (advanced; changes how prompts are packed for the LLM)
# -----------------------------------------------------------------------------
# Safe default: off (matches PlumberLintConfig.context_compression default).
MATRYCA_PLUMBER_CONTEXT_COMPRESSION=false
MATRYCA_PLUMBER_COMPRESSION_TRIGGER_TOKENS=100000
MATRYCA_PLUMBER_COMPRESSION_TARGET_TOKENS=30000

# -----------------------------------------------------------------------------
# Cognitive lint modules (mutating / AI-heavy — keep false unless you opt in)
# -----------------------------------------------------------------------------
MATRYCA_LINT_HEAL_DANGLING=false
MATRYCA_LINT_DANGLING_MAX_WORDS=50
MATRYCA_LINT_ENTITY_CONSOLIDATION=false
MATRYCA_LINT_SIMILARITY_THRESHOLD=0.85
MATRYCA_LINT_AUTO_SPLIT=false
MATRYCA_LINT_SPLIT_BLOCK_THRESHOLD=15
MATRYCA_LINT_PROPERTY_HYGIENE=false
# Safe default: explicit false (code default is true when unset — opt in to inference).
MATRYCA_LINT_INFER_MISSING_PROPERTIES=false
MATRYCA_LINT_BACKPROPAGATE_LINKS=false
MATRYCA_LINT_SEMANTIC_ROUTING=false
MATRYCA_LINT_MARPA_FRAMEWORK=false
# When true, skip inline semantic corrections (fewer automatic text edits).
MATRYCA_LINT_DISABLE_SEMANTIC_CORRECTIONS=true

# Optional: path to YAML property rules; empty uses matryca-plumber-rules.yml in
# the graph root when present (src/agent/plumber_config.py).
MATRYCA_LINT_PROPERTY_RULES=

# -----------------------------------------------------------------------------
# Semantic inference cache (on-disk under .matryca_semantic_cache)
# -----------------------------------------------------------------------------
# TTL in seconds for cache entries (min 60 when set; code default 86400).
MATRYCA_LINT_SEMANTIC_CACHE_TTL=86400
