# Logseq Local HTTP API (see Logseq plugin / API docs for token setup)
LOGSEQ_API_TOKEN=
LOGSEQ_API_URL=http://localhost:12315

# Absolute path to the Logseq graph directory on this machine (Markdown pages / journals)
LOGSEQ_GRAPH_PATH=

# Optional: L1 "fast context" — a single .md file or a directory of .md files (see read_l1_memory)
# If unset and LOGSEQ_GRAPH_PATH is set, reads from <graph-parent>/matryca-l1/*.md when present.
MATRYCA_L1_PATH=

# Optional: matryca-wiki.yml path (defaults to $LOGSEQ_GRAPH_PATH/matryca-wiki.yml)
MATRYCA_WIKI_CONFIG=

# Optional: run `git add -A && git commit` on LOGSEQ_GRAPH_PATH before write_logseq_outline (rollback safety)
MATRYCA_GIT_SNAPSHOT_ON_WRITE=false
