# =============================================================================
# Matryca Plumber — environment template (aligned with src/)
# =============================================================================
# On first startup Matryca Plumber copies this file to ".env" when missing.
#
# Comment legend (every tunable key):
#   Default (code) — value used when the variable is unset or empty
#   Template       — value on the line below for new installs (safe 16GB profile)
#
# LLM keys: LLM_BASE_URL / LLM_MODEL_NAME override MATRYCA_LM_* when non-empty
# (Settings UI persists LLM_*). Keep both pairs in sync if you set both.
#
# Docs: docs/openspec/runtime-bootstrap.md · CONTRIBUTING.md · SECURITY.md
# =============================================================================


# #############################################################################
# OPERATOR ESSENTIALS — start here
# #############################################################################
# Settings you should understand before running the daemon or Sovereign UI.
# Most of these map to the Settings drawer or pre-flight onboarding.
# #############################################################################

# -----------------------------------------------------------------------------
# Graph & wiki paths
# -----------------------------------------------------------------------------
# Logseq OG vault root (must contain pages/). src/graph/graph_path_validate.py
# Default (code): (empty — daemon refuses to start)
# Template: replace with your absolute vault path
LOGSEQ_GRAPH_PATH="/absolute/path/to/your/Logseq/graph"

# L1 memory Markdown file or directory. src/agent/l1_memory.py
# Default (code): <parent-of-LOGSEQ_GRAPH_PATH>/matryca-l1/
# Template: (unset — use parent matryca-l1)
# MATRYCA_L1_PATH=

# Explicit matryca-wiki.yml path. src/config.py
# Default (code): <LOGSEQ_GRAPH_PATH>/matryca-wiki.yml when that file exists
# Template: (empty — auto)
MATRYCA_WIKI_CONFIG=

# -----------------------------------------------------------------------------
# Local LLM (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Model id sent to the OpenAI-compatible API. src/agent/plumber_config.py
# Default (code): local-model
# Template (recommended / tested): gemma-4-e4b-it (see README.md)
MATRYCA_LM_MODEL="gemma-4-e4b-it"

# Base URL (/v1 appended for bare host roots). src/agent/plumber_config.py
# Default (code): http://localhost:1234/v1
# Template: same
MATRYCA_LM_BASE_URL=http://localhost:1234/v1

# Canonical names written by the Settings UI (override MATRYCA_LM_* when non-empty).
# Default (code): (empty — fall back to MATRYCA_LM_*)
# Template: (unset until first UI save)
# LLM_BASE_URL=
# LLM_MODEL_NAME=

# API key header for local servers (often ignored). src/agent/plumber_config.py
# Default (code): dummy-key
# Template: same
LLM_API_KEY=dummy-key

# -----------------------------------------------------------------------------
# Daemon cadence
# -----------------------------------------------------------------------------
# Maintenance daemon poll interval (seconds). src/agent/maintenance_daemon.py
# Default (code): 30
# Template: same
MATRYCA_PLUMBER_POLL_SECONDS=30

# Link rot / missing-asset hygiene (sidecar `.matryca_link_registry.json`). src/graph/link_verification.py
# Default (code): true
# Template: same
MATRYCA_LINK_VERIFY_ENABLED=true

# Consecutive failed checks before `dead-link::` / `missing-asset::` flags. src/graph/link_verification.py
# Default (code): 2
# Template: same
MATRYCA_LINK_VERIFY_STRIKES=2

# Max links verified per daemon duty cycle. src/graph/link_verification.py
# Default (code): 25
MATRYCA_LINK_VERIFY_BATCH=25

# HTTP HEAD timeout (seconds) for external URLs. src/graph/link_verification.py
# Default (code): 8
MATRYCA_LINK_VERIFY_TIMEOUT=8

# Upsert one cumulative activity bullet in today's journal (`- 🤖 Matryca Activity — …`). src/agent/journey_log.py
# Default (code): true
# Template: same
MATRYCA_JOURNEY_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Logs (paths only — redaction is in Advanced)
# -----------------------------------------------------------------------------
# JSONL ops log for token tracing. src/utils/config_paths.py
# Default (code): logs/matryca_plumber_ops.log (under repo root)
# Template: same
MATRYCA_PLUMBER_LOG_PATH="logs/matryca_plumber_ops.log"

# Rotating Loguru log. src/utils/config_paths.py
# Default (code): logs/matryca_plumber.log (under repo root)
# Template: same
MATRYCA_LOGURU_LOG_PATH="logs/matryca_plumber.log"

# -----------------------------------------------------------------------------
# Hardware pacing (also in Settings drawer)
# -----------------------------------------------------------------------------
# Pause after bootstrap LLM turns. src/agent/plumber_config.py
# Default (code): 2.0
# Template (16GB CPU profile): 5.0
MATRYCA_THERMAL_DELAY_BOOTSTRAP=5.0

# Pause after cognitive / Phase-2 LLM turns.
# Default (code): 2.0
# Template (16GB CPU profile): 5.0
MATRYCA_THERMAL_DELAY_COGNITIVE=5.0

# POSIX niceness / low-priority mode. src/agent/plumber_config.py
# Default (code): true
# Template: true
MATRYCA_PLUMBER_LOW_PRIORITY_MODE=true

# -----------------------------------------------------------------------------
# Map-reduce (large pages — also in Settings drawer)
# -----------------------------------------------------------------------------
# Page size (chars) that triggers MapReduce harvest. src/agent/plumber_config.py
# Default (code): 25000
# Template: same
MATRYCA_PLUMBER_MAPREDUCE_TRIGGER_CHARS=25000

# Max chars per MapReduce chunk.
# Default (code): 15000
# Template: same
MATRYCA_PLUMBER_MAPREDUCE_CHUNK_CHARS=15000

# -----------------------------------------------------------------------------
# Sovereign UI (loopback-first)
# -----------------------------------------------------------------------------
# Bearer token for /api/* (empty = auto per process). src/cli/ui_auth.py
# Default (code): auto-generated when empty
# Template: (empty on trusted single-user loopback)
MATRYCA_UI_TOKEN=

# Bind UI to 0.0.0.0 (LAN). /api/auth/session stays loopback-only. src/cli/ui_auth.py
# Default (code): false
# Template: false
# Range / notes: requires MATRYCA_UI_TOKEN when true
MATRYCA_UI_ALLOW_LAN=false


# #############################################################################
# ADVANCED / HIGH IMPACT — change only if you understand the risk
# #############################################################################
# WARNING: Variables below can mutate your Logseq graph, weaken locking,
# expose the UI on the network, enable full MCP graph R/W, or change LLM
# safety limits. Defaults favor a safe test-vault profile (lint OFF).
# Prefer the Settings drawer for lint toggles that are exposed there.
# systemd/LaunchAgent only forwards LOGSEQ_GRAPH_PATH, MATRYCA_L1_PATH,
# MATRYCA_WIKI_CONFIG, MATRYCA_GIT_ROBOT_COMMIT — run from repo cwd
# with .env loaded for full configuration.
# #############################################################################

# -----------------------------------------------------------------------------
# Security, MCP, locking, diagnostics
# -----------------------------------------------------------------------------
# Post-write surgical git commit per robot-modified .md file. src/daemon/git_audit.py
# Default (code): enabled when graph root is a git repo
# Template: true
# Set to false to disable robot(matryca): commits
MATRYCA_GIT_ROBOT_COMMIT=true

# Debounce window (ms) for pages/journals file watcher. src/daemon/file_watcher.py
# Default (code): 750
# Range: 500-1000
MATRYCA_WATCH_DEBOUNCE_MS=750

# Verbose telemetry (UUIDs, full MCP errors). src/agent/mcp_telemetry.py
# Default (code): false
# Template: false
MATRYCA_DEBUG=false

# Allow daemon without POSIX flock. src/graph/page_write_lock.py
# Default (code): false
# Template: false
MATRYCA_ALLOW_FLOCK_DEGRADATION=false

# FastMCP stdio when matryca-plumber has no CLI args. src/plumber_entry.py
# Default (code): false
# Template: false
# Range / notes: MCP host has full graph R/W — trust the host process
MATRYCA_MCP_ENABLED=false

# Refuse UI startup without MATRYCA_UI_TOKEN. src/cli/ui_auth.py
# Default (code): false
# Template: false
MATRYCA_UI_REQUIRE_EXPLICIT_TOKEN=false

# Expose FastAPI /docs and /openapi.json. src/cli/ui_server.py
# Default (code): false
# Template: false
MATRYCA_UI_ENABLE_DOCS=false

# Per-IP /api/* rate limits (authenticated / unauthenticated). src/cli/ui_server.py
# Default (code): 120 / 30 (floors 10 / 5)
# Template: same
MATRYCA_UI_RATE_LIMIT_PER_MINUTE=120
MATRYCA_UI_RATE_LIMIT_UNAUTH_PER_MINUTE=30

# Extra roots allowed for LOGSEQ_GRAPH_PATH in Settings. src/utils/config_paths.py
# Default (code): home, repo, temp, current graph only
# MATRYCA_ALLOWED_GRAPH_ROOTS=

# Redact secrets in ops JSONL. src/utils/secret_redaction.py
# Default (code): true
# Template: true
# Range / notes: alias MATRYCA_LOG_REDACT_SECRETS
MATRYCA_PLUMBER_LOG_REDACT_SECRETS=true

# -----------------------------------------------------------------------------
# LLM limits & debug (resilience / anti-loop)
# -----------------------------------------------------------------------------
# Transient HTTP retries for LLM calls. src/agent/llm_client.py
# Default (code): 3
# MATRYCA_LLM_TRANSPORT_RETRIES=3

# Cap structured JSON completions (clamp 256–8192). src/agent/plumber_config.py
# Default (code): 2048
# MATRYCA_LLM_MAX_COMPLETION_TOKENS=2048

# Cap context-compression markdown completions (clamp 256–4096).
# Default (code): 1536
# MATRYCA_LLM_MAX_COMPRESSION_TOKENS=1536

# Character cap after prose sanitization (clamp 2000–32000). src/utils/json_repair.py
# Default (code): 12000
# MATRYCA_LLM_PROSE_COMPLETION_MAX_CHARS=12000

# NDJSON trace for JSON resilience debugging. src/utils/agent_debug_log.py
# Default (code): false
# MATRYCA_LLM_DEBUG_JSON=false
# MATRYCA_LLM_DEBUG_LOG_PATH=.cursor/debug-llm.jsonl

# Cap Ermes cluster neighborhood injection (clamp 1000–24000).
# Default (code): 8000
# MATRYCA_CLUSTER_FOCUS_MAX_CHARS=8000

# Max JSON bytes per semantic cache entry (clamp 4096–2097152).
# Default (code): 262144
# MATRYCA_SEMANTIC_CACHE_MAX_PAYLOAD_BYTES=262144

# -----------------------------------------------------------------------------
# Context compression (mutates how history is packed for the LLM)
# -----------------------------------------------------------------------------
# Enable rolling history condensation. src/agent/plumber_config.py
# Default (code): false
# Template: false
MATRYCA_PLUMBER_CONTEXT_COMPRESSION=false

# Estimated-token threshold to start compression.
# Default (code): 100000
# Template: same
MATRYCA_PLUMBER_COMPRESSION_TRIGGER_TOKENS=100000

# Target token budget after compression.
# Default (code): 30000
# Template: same
MATRYCA_PLUMBER_COMPRESSION_TARGET_TOKENS=30000

# -----------------------------------------------------------------------------
# Cognitive lint modules (mutating / AI-heavy — keep false on production vaults)
# -----------------------------------------------------------------------------
# Heal dangling link references. Default (code): false | Template: false
MATRYCA_LINT_HEAL_DANGLING=false

# Max words for dangling heal context. Default (code): 50 | Template: same
MATRYCA_LINT_DANGLING_MAX_WORDS=50

# Entity consolidation. Default (code): false | Template: false
MATRYCA_LINT_ENTITY_CONSOLIDATION=false

# Similarity threshold for entity merge. Default (code): 0.85 | Template: same
MATRYCA_LINT_SIMILARITY_THRESHOLD=0.85

# Auto-split oversized blocks. Default (code): false | Template: false
MATRYCA_LINT_AUTO_SPLIT=false

# Block count threshold for auto-split. Default (code): 15 | Template: same
MATRYCA_LINT_SPLIT_BLOCK_THRESHOLD=15

# Property hygiene passes. Default (code): false | Template: false
MATRYCA_LINT_PROPERTY_HYGIENE=false

# Infer missing properties via LLM. Default (code): true when unset; Template: false (safe)
MATRYCA_LINT_INFER_MISSING_PROPERTIES=false

# Backpropagate [[links]]. Default (code): false | Template: false
MATRYCA_LINT_BACKPROPAGATE_LINKS=false

# Semantic routing hints. Default (code): false | Template: false
MATRYCA_LINT_SEMANTIC_ROUTING=false

# MARPA framework lint. Default (code): false | Template: false
MATRYCA_LINT_MARPA_FRAMEWORK=false

# When true, skip inline semantic text corrections. Default (code): true | Template: true
MATRYCA_LINT_DISABLE_SEMANTIC_CORRECTIONS=true

# YAML property rules path. Default (code): <graph>/matryca-plumber-rules.yml if present
MATRYCA_LINT_PROPERTY_RULES=

# -----------------------------------------------------------------------------
# Semantic inference cache (.matryca_semantic_cache)
# -----------------------------------------------------------------------------
# On-disk cache TTL (seconds, min 60 when set). src/agent/plumber_modules/semantic_cache_router.py
# Default (code): 86400
# Template: same
MATRYCA_LINT_SEMANTIC_CACHE_TTL=86400

# In-process LRU entry cap. Default (code): 512 | Template: same
MATRYCA_SEMANTIC_CACHE_MEMORY_ENTRIES=512

# -----------------------------------------------------------------------------
# Process priority (Linux/macOS + psutil [edge])
# -----------------------------------------------------------------------------
# Nice level when CPU sandbox applies (0–19). src/agent/process_priority.py
# Default (code): 19
# MATRYCA_PLUMBER_NICE_LEVEL=19

# Linux ionice idle class when psutil available.
# Default (code): true
# MATRYCA_PLUMBER_IONICE_IDLE=true

# -----------------------------------------------------------------------------
# v1.8 Edge computing & performance (16GB laptop / large vaults)
# Docs: docs/v1.8-OPTIMIZATION-PLAN.md · docs/openspec/llm-performance.md
# -----------------------------------------------------------------------------
# Soft RSS budget for daemon telemetry (MB). src/agent/memory_budget.py
# Default (code): 4096
# Template: same
MATRYCA_RAM_BUDGET_MB=4096

# BM25 index mode: resident | ondemand. src/graph/generational_cache.py
# Default (code): resident
# Template: same
MATRYCA_BM25_MODE=resident

# AliasIndex footer cap in stable user block (chars). src/agent/page_prompt_session.py
# Default (code): 2048
# Template: same
MATRYCA_ALIAS_PROMPT_MAX_CHARS=2048

# yield_host() every N files during bootstrap. src/agent/cooperative_yield.py
# Default (code): 25
# Template: same
MATRYCA_BOOTSTRAP_YIELD_EVERY=25

# Daemon state checkpoint interval during Phase 1. Default (code): 50
MATRYCA_BOOTSTRAP_CHECKPOINT_EVERY=50

# Phase 1 pill history flush interval (bootstrap_recent). Default (code): 5
MATRYCA_BOOTSTRAP_PILL_CHECKPOINT_EVERY=5

# Cooperative telemetry heartbeat while daemon is active (seconds). Default (code): 5
MATRYCA_TELEMETRY_HEARTBEAT_SECONDS=5

# Micro-pause (ms) after non-LLM harvest steps. Default (code): 2
MATRYCA_BOOTSTRAP_IO_BATCH_PAUSE_MS=2

# Extra sleep (ms) on yield_host ticks (HDD tuning). Default (code): 0
MATRYCA_YIELD_SLEEP_MS=0

# Full vs minimal cluster ack in Ermes history. src/agent/llm_client.py
# Default (code): false
# Template: same
MATRYCA_LLM_CLUSTER_HISTORY=false

# CPU affinity + idle I/O (needs psutil: pip install matryca-plumber[edge]).
# Default (code): follows MATRYCA_PLUMBER_LOW_PRIORITY_MODE when unset
# Template: true
MATRYCA_CPU_SANDBOX=true

# Explicit CPU indices (comma-separated), e.g. 6,7. Default (code): auto tail cores
# MATRYCA_PLUMBER_CPU_AFFINITY=

# Mmap large markdown reads during bootstrap. src/graph/markdown_io.py
# Default (code): true
# Template: same
MATRYCA_GRAPH_READ_MMAP=true

# Minimum file size (bytes) to use mmap. Default (code): 4096
MATRYCA_MMAP_MIN_BYTES=4096

# -----------------------------------------------------------------------------
# DEPRECATED / RESERVED (not read by runtime — do not copy into new .env)
# -----------------------------------------------------------------------------
# v1.8+ structured output: src/agent/llm_client.py probe_backend()
# MATRYCA_LM_INSTRUCTOR_MODE=JSON_SCHEMA
# MATRYCA_LM_INSTRUCTOR_FALLBACK=MD_JSON
# RESERVED — future prompt-cache integration (not wired yet)
# MATRYCA_LLM_PROMPT_CACHE_MODE=off

# Override Logseq page title for Telos/AI Constraints identity (optional). src/daemon/config_layer.py
# Default (code): matryca/config then matryca-config under pages/
# Template:
MATRYCA_IDENTITY_CONFIG_PAGE=

# Ingest destination Logseq page title (optional). src/agent/ingestion.py
# Default (code): daily page Ingest/YYYY-MM-DD -> pages/Ingest___YYYY-MM-DD.md
# Template: (empty — use daily ingest page)
# Example fixed inbox: AI_Inbox -> pages/AI_Inbox.md
MATRYCA_INGEST_PAGE=

# Dual block embeddings (content + applicability vectors). src/semantic/
# Default (code): false — daemon indexes after semantic writes when true
# Template: false
MATRYCA_DUAL_EMBEDDING_ENABLED=false

# Hybrid retrieval weights (cosine content + cosine applicability). src/semantic/search.py
# Default (code): 0.5 / 0.5
MATRYCA_WEIGHT_CONTENT=0.5
MATRYCA_WEIGHT_APPLICABILITY=0.5

# Embedding model for dual vectors (OpenAI-compatible /v1/embeddings). src/semantic/embedding.py
# Default (code): text-embedding-3-small
# Host: MATRYCA_EMBEDDING_BASE_URL when set, else MATRYCA_LM_BASE_URL / LLM_BASE_URL
MATRYCA_EMBEDDING_MODEL=text-embedding-3-small
# MATRYCA_EMBEDDING_BASE_URL=

# Max blocks scored per semantic search (large vault safety cap). src/semantic/search.py
# Default (code): 50000
# MATRYCA_SEMANTIC_SEARCH_MAX_CANDIDATES=50000

